        <mxCell id="uc05_usecase_title" value="&lt;b&gt;UC05 - Βασική ροή&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;fontStyle=1;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="158" width="224" height="18" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s1" value="1. Ο Διαχειριστής επιλέγει «Επεξεργασία λίστας υλικών»." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="194" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s2" value="2. Το σύστημα εμφανίζει λίστα προϊόντων." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="246" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s3" value="3. Ο Διαχειριστής επιλέγει προϊόν." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="446" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s4" value="4. Το σύστημα εμφανίζει διαθέσιμα υλικά." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="636" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s5" value="5. Ο Διαχειριστής επιλέγει υλικά και ποσότητες." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="700" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s6" value="6. Το σύστημα ελέγχει τις ποσότητες." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="748" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s7" value="7. Αν υπάρχει σφάλμα, εμφανίζεται μήνυμα διόρθωσης." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="828" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s8" value="8. Αν είναι έγκυρα, ενημερώνεται η λίστα υλικών και το κόστος." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="896" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc05_usecase_s9" value="9. Το σύστημα εμφανίζει επιβεβαίωση και επιστρέφει στο μενού." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="990" width="224" height="42" as="geometry"/></mxCell>
