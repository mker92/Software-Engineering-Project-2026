        <mxCell id="uc04_title" value="Sequence Diagram - Δημιουργία νέου προϊόντος" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="500" height="28" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=8;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="30" y="150" width="240" height="865" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_title" value="&lt;b&gt;UC04 - Βασική ροή&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;fontStyle=1;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="158" width="224" height="18" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s1" value="1. Ο Διαχειριστής επιλέγει «Δημιουργία νέου προϊόντος»." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="194" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s2" value="2. Το σύστημα εμφανίζει φόρμα νέου προϊόντος." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="240" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s3" value="3. Ο Διαχειριστής καταχωρεί τα στοιχεία του προϊόντος." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="294" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s4" value="4. Το σύστημα ελέγχει τα στοιχεία και αν υπάρχει ήδη προϊόν." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="346" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s5" value="5. Αν υπάρχει σφάλμα, εμφανίζεται μήνυμα διόρθωσης." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="525" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s6" value="6. Αν τα στοιχεία είναι έγκυρα, καταχωρείται το προϊόν." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="642" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s7" value="7. Η ροή συνεχίζεται με &lt;&lt;include&gt;&gt; στο SD05." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="800" width="224" height="42" as="geometry"/></mxCell>
        <mxCell id="uc04_usecase_s8" value="8. Το σύστημα εμφανίζει επιβεβαίωση και επιστρέφει στο μενού." style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;align=left;verticalAlign=top;spacing=0;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="38" y="924" width="224" height="42" as="geometry"/></mxCell>
